{
  "transport": {
    "pipeName": "VirtualDofMatrix",
    "controlPipeName": "VirtualDofMatrix.Control",
    "broadcastPipeName": "VirtualDofMatrix.Broadcast",
    "broadcastMaxQueuePerClient": 8
  },
  "routing": {
    "routingSchemaVersion": "1",
    "toyConfigIniPath": "toys.ini"
  },
  "matrix": {
    "fillGapEnabled": false,
    "visual": {
      "offStateTintR": 15,
      "offStateTintG": 15,
      "offStateTintB": 15,
      "offStateAlpha": 0.5
    }
  },
  "window": {
    "lockAspectRatio": true,
    "backgroundVisible": true,
    "backgroundColor": "#000000"
  },
  "debug": {
    "showDebug": false,
    "logProtocol": false,
    "logFrames": false
  },
  "settings": {
    "dofConfigFolderPath": "C:\\DirectOutput\\Config",
    "cabinetXmlPath": "C:\\DirectOutput\\Config\\Cabinet.xml",
    "cabinetToyName": "Matrix1",
    "autoUpdateCabinetOnResolutionChange": true,
    "visualQuality": "High",
    "defaultStripBulbSize": 32
  }
}
