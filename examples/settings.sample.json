{
  "serial": {
    "portName": "COM2",
    "baudRate": 9600,
    "maxLedsPerChannel": 1100,
    "maxStrips": 8,
    "readTimeoutMs": 200,
    "writeTimeoutMs": 1000,
    "dtrEnable": true
  },
  "matrix": {
    "width": 256,
    "height": 32,
    "mapping": "TopDownAlternateRightLeft",
    "dotShape": "circle",
    "dotSize": 2,
    "dotSpacing": 2,
    "brightness": 1.0,
    "gamma": 1.0,
    "instantTrigger": true,
    "visual": {
      "offStateTintR": 150,
      "offStateTintG": 155,
      "offStateTintB": 170,
      "offStateAlpha": 0.22,
      "lensFalloff": 0.45,
      "specularHotspot": 0.28,
      "rimHighlight": 0.22
    }
  },
  "window": {
    "alwaysOnTop": true,
    "borderless": true,
    "left": 100,
    "top": 100,
    "width": 1280,
    "height": 320
  },
  "debug": {
    "showDebug": false,
    "logProtocol": true,
    "logFrames": false
  }
}
