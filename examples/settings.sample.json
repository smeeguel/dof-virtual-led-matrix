{
  "transport": {
    "pipeName": "VirtualDofMatrix"
  },
  "matrix": {
    "renderer": "gpu",
    "width": 128,
    "height": 32,
    "mapping": "TopDownAlternateRightLeft",
    "dotShape": "circle",
    "minDotSpacing": 2,
    "brightness": 1.0,
    "gamma": 0.8,
    "toneMapping": {
      "enabled": true,
      "kneeStart": 0.95,
      "strength": 0.55
    },
    "temporalSmoothing": {
      "enabled": false,
      "riseAlpha": 0.5,
      "fallAlpha": 0.3
    },
    "visual": {
      "flatShading": false,
      "fullBrightnessRadiusMinPct": 0.8,
      "offStateTintR": 20,
      "offStateTintG": 20,
      "offStateTintB": 20,
      "offStateAlpha": 0.2,
      "lensFalloff": 0.45,
      "specularHotspot": 0.28,
      "rimHighlight": 0.22
    },
    "bloom": {
      "enabled": true,
      "qualityPreset": "medium",
      "threshold": 0.55,
      "smallRadius": 2,
      "wideRadius": 5,
      "smallStrength": 0.6,
      "wideStrength": 0.25,
      "bufferScaleDivisor": 2
    }
  },
  "window": {
    "alwaysOnTop": true,
    "borderless": true,
    "left": 10,
    "top": 6,
    "width": 1412,
    "height": 353
  },
  "debug": {
    "showDebug": false,
    "logProtocol": false,
    "logFrames": false
  },
  "settings": {
    "cabinetXmlPath": "C:\\DirectOutput\\Config\\Cabinet.xml",
    "cabinetToyName": "Matrix1",
    "autoUpdateCabinetOnResolutionChange": true,
    "visualQuality": "High"
  }
}
