{
  "serial": {
    "portName": "COM2",
    "virtualTransmitterPortName": null,
    "virtualListenerPortName": null,
    "autoProvisionVirtualPair": true,
    "virtualPairActivateCommand": "powershell -ExecutionPolicy Bypass -File \"C:\\Tools\\vspe-create-pair.ps1\" -Transmitter {tx} -Listener {rx}",
    "virtualPairDeactivateCommand": "powershell -ExecutionPolicy Bypass -File \"C:\\Tools\\vspe-remove-pair.ps1\" -Transmitter {tx} -Listener {rx}",
    "virtualPairCommandTimeoutMs": 15000,
    "virtualPairMaxAllocationAttempts": 64,
    "baudRate": 9600,
    "maxLedsPerChannel": 1100,
    "maxStrips": 8,
    "readTimeoutMs": 200,
    "writeTimeoutMs": 1000,
    "dtrEnable": true
  },
  "matrix": {
    "width": 256,
    "height": 32,
    "mapping": "TopDownAlternateRightLeft",
    "dotShape": "circle",
    "dotSize": 3,
    "dotSpacing": 1,
    "brightness": 1.0,
    "gamma": 1.0,
    "instantTrigger": true
  },
  "window": {
    "alwaysOnTop": true,
    "borderless": true,
    "left": 100,
    "top": 100,
    "width": 1280,
    "height": 320
  },
  "debug": {
    "showDebug": false,
    "logProtocol": true,
    "logFrames": false
  }
}
