{
  "transport": {
    "mode": "namedPipe",
    "pipeName": "VirtualDofMatrix"
  },
  "serial": {
    "portName": "COM2",
    "baudRate": 9600,
    "maxLedsPerChannel": 1100,
    "maxStrips": 8,
    "readTimeoutMs": 200,
    "writeTimeoutMs": 1000,
    "dtrEnable": true
  },
  "matrix": {
    "renderer": "primitive",
    "width": 64,
    "height": 16,
    "mapping": "TopDownAlternateRightLeft",
    "dotShape": "circle",
    "minDotSpacing": 2,
    "brightness": 1.0,
    "gamma": 1.0,
    "toneMapping": {
      "enabled": false,
      "kneeStart": 0.85,
      "strength": 0.35
    },
    "temporalSmoothing": {
      "enabled": false,
      "riseAlpha": 1.0,
      "fallAlpha": 1.0
    },
    "bloom": {
      "enabled": true,
      "qualityPreset": "medium",
      "threshold": 0.55,
      "smallRadius": 2,
      "wideRadius": 5,
      "smallStrength": 0.6,
      "wideStrength": 0.25,
      "bufferScaleDivisor": 2
    },
    "visual": {
      "offStateTintR": 150,
      "offStateTintG": 155,
      "offStateTintB": 170,
      "offStateAlpha": 0.22,
      "lensFalloff": 0.45,
      "specularHotspot": 0.28,
      "rimHighlight": 0.22
    }
  },
  "window": {
    "alwaysOnTop": true,
    "borderless": true,
    "left": 100,
    "top": 100,
    "width": 1280,
    "height": 320
  },
  "debug": {
    "showDebug": false,
    "logProtocol": true,
    "logFrames": false
  },
  "settings": {
    "cabinetXmlPath": "C:/DirectOutput/Config/Cabinet.xml",
    "cabinetToyName": "Matrix1",
    "autoUpdateCabinetOnResolutionChange": true,
    "visualQuality": "Medium"
  }
}