<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Virtual DOF Matrix"
    Manufacturer="Virtual DOF Matrix"
    Version="$(var.ProductVersion)"
    UpgradeCode="C817B8D6-BF5E-460B-8F7F-6EB79BB66D31"
    Scope="perMachine"
    Language="1033">

    <SummaryInformation Description="Virtual DOF Matrix installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Virtual DOF Matrix is already installed." />
    <MediaTemplate />

    <!-- Minimal install footprint so the MSI can be introduced without changing existing ZIP release flow yet. -->
    <ComponentGroup Id="InstallerMarkerComponents" Directory="ProgramFiles64Folder">
      <Component Id="InstallMarker" Guid="*">
        <RegistryValue
          Root="HKLM"
          Key="Software\VirtualDofMatrix"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="MainFeature" Title="Virtual DOF Matrix" Level="1">
      <ComponentGroupRef Id="InstallerMarkerComponents" />
    </Feature>
  </Package>
</Wix>
