<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="$(var.ProductName)"
    Manufacturer="$(var.Manufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="C817B8D6-BF5E-460B-8F7F-6EB79BB66D31"
    Scope="perMachine"
    Language="1033">

    <SummaryInformation Description="Virtual DOF Matrix installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Virtual DOF Matrix is already installed." />
    <!-- Embed cabinets into the MSI so GitHub releases can ship a single installer file without detached cab*.cab payloads. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ARP metadata: name/publisher/version come from Package attributes above; extra fields are explicit here. -->
    <Property Id="ARPCOMMENTS" Value="Virtual DOF Matrix emulator/viewer for DOF serial output." />
    <!-- UI properties are marked Secure so they can flow from client-side UI into deferred execute-sequence custom actions. -->
    <Property Id="DOFCONFIGPATH" Value="C:\DirectOutput\Config" Secure="yes" />
    <Property Id="BACKUP_ENABLED" Value="1" Secure="yes" />
    <Property Id="BACKUP_PATH" Secure="yes" />
    <Property Id="DOFROOTPATH" Secure="yes" />
    <Property Id="TOY_TEMPLATE" Value="single_matrix" Secure="yes" />
    <!-- Keep the Finish dialog launch checkbox visible and enabled by default for fresh installs. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Virtual DOF Matrix" />
    <!-- WixUI_InstallDir wires WIXUI_INSTALLDIR internally via InstallDirectory="INSTALLFOLDER"; do not redeclare it here. -->

    <!-- Install root defaults to Program Files and remains user-selectable through the install-directory dialog. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="VirtualDofMatrix" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="$(var.ProductName)" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="DofPayloadFiles" />
    </Feature>

    <!-- Harvest published app artifacts; CI passes InstallerAppPublishDir to package release-ready binaries. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AppPublishDir)**" />
    </ComponentGroup>
    <!-- Ship DOF templates + DirectOutput architecture DLL payload so deferred custom actions can copy from [INSTALLFOLDER]\DOF\. -->
    <ComponentGroup Id="DofPayloadFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DofPayloadDir)**" />
    </ComponentGroup>

    <!-- Provide install-directory selection UI in MSI. -->
    <!-- Bind the MSI license dialog to the repository EULA content instead of the WiX placeholder lorem ipsum. -->
    <WixVariable Id="WixUILicenseRtf" Value="Eula.rtf" />
    <!-- WiX UI extension wiring lives in ui:WixUI, while button event publishing uses the core Publish element under UI. -->
    <UI>
      <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
      <Dialog Id="TemplateSelectDlg" Width="370" Height="270" Title="[ProductName] - Choose LED template">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="Choose LED template" />
        <Control Id="Description" Type="Text" X="20" Y="23" Width="330" Height="24"
          Text="Select the virtual LED layout to install into your DOF config." />

        <!-- Keep this picker intentionally simple so the install flow remains InstallDir -> TemplateSelect -> VerifyReady. -->
        <Control Id="TemplateLabel" Type="Text" X="20" Y="70" Width="330" Height="12" Text="LED template:" />
        <Control Id="TemplateRadioGroup" Type="RadioButtonGroup" X="20" Y="88" Width="330" Height="68" Property="TOY_TEMPLATE">
          <RadioButtonGroup Property="TOY_TEMPLATE">
            <RadioButton Value="single_matrix" X="0" Y="0" Width="320" Height="16" Text="Single matrix" />
            <RadioButton Value="matrix_plus_3_strips" X="0" Y="24" Width="320" Height="16" Text="Matrix and flasher strips" />
          </RadioButtonGroup>
        </Control>

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <!-- Keep stock WixUI_InstallDir SetTargetPath wiring intact and only override post-path navigation. -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="TemplateSelectDlg" Order="5" Condition="1" />
      <!-- Keep back-navigation symmetrical with the inserted template step: VerifyReady -> TemplateSelect -> InstallDir. -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="TemplateSelectDlg" Order="5" Condition="1" />
      <!-- Trigger launch from the Exit dialog Finish button only when the optional checkbox remains enabled. -->
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchInstalledApp"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <!-- DTF custom actions must reference the generated *.CA.dll payload, not the plain project output DLL. -->
    <Binary Id="CustomActionBinary" SourceFile="$(var.CustomActions.TargetDir)VirtualDofMatrix.CustomActions.CA.dll" />
    <CustomAction Id="ValidateInstallerSelections" BinaryRef="CustomActionBinary" DllEntry="ValidateInstallerSelections" Execute="immediate" Return="check" />
    <CustomAction Id="ApplyDofTemplateAndBinaries" BinaryRef="CustomActionBinary" DllEntry="ApplyDofTemplateAndBinaries" Execute="deferred" Impersonate="no" Return="check" />
    <CustomAction
      Id="SetApplyDofTemplateAndBinariesData"
      Property="ApplyDofTemplateAndBinaries"
      Value="DOFCONFIGPATH=[DOFCONFIGPATH];DOFROOTPATH=[DOFROOTPATH];BACKUP_ENABLED=[BACKUP_ENABLED];BACKUP_PATH=[BACKUP_PATH];TOY_TEMPLATE=[TOY_TEMPLATE];INSTALLFOLDER=[INSTALLFOLDER]"
      Execute="immediate" />

    <CustomAction
      Id="LaunchInstalledApp"
      BinaryRef="Wix4UtilCA_X64"
      DllEntry="WixShellExec"
      Impersonate="yes" />
    <!-- Populate WixShellExecTarget in the UI sequence after directory resolution so INSTALLFOLDER expansion is legal. -->
    <SetProperty
      Id="WixShellExecTarget"
      Value="[INSTALLFOLDER]VirtualDofMatrix.App.exe"
      After="CostFinalize"
      Sequence="ui" />

    <InstallExecuteSequence>
      <!-- Stage public UI properties into deferred CustomActionData so execute-sequence logic sees the final user selections. -->
      <Custom Action="SetApplyDofTemplateAndBinariesData" Before="ApplyDofTemplateAndBinaries" Condition="NOT Installed" />
      <Custom Action="ValidateInstallerSelections" Before="SetApplyDofTemplateAndBinariesData" Condition="NOT Installed" />
      <Custom Action="ApplyDofTemplateAndBinaries" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Package>
</Wix>
