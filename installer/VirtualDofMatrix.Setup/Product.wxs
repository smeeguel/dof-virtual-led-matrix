<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="$(var.ProductName)"
    Manufacturer="$(var.Manufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="C817B8D6-BF5E-460B-8F7F-6EB79BB66D31"
    Scope="perMachine"
    Language="1033">

    <SummaryInformation Description="Virtual DOF Matrix installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Virtual DOF Matrix is already installed." />
    <!-- Embed cabinets into the MSI so GitHub releases can ship a single installer file without detached cab*.cab payloads. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ARP metadata: name/publisher/version come from Package attributes above; extra fields are explicit here. -->
    <Property Id="ARPCOMMENTS" Value="Virtual DOF Matrix emulator/viewer for DOF serial output." />
    <!-- UI properties are marked Secure so they can flow from client-side UI into deferred execute-sequence custom actions. -->
    <Property Id="DOFCONFIGPATH" Value="C:\DirectOutput\Config" Secure="yes" />
    <Property Id="DOF_DETECTED" Value="0" Secure="yes" />
    <Property Id="BACKUP_ENABLED" Value="1" Secure="yes" />
    <Property Id="BACKUP_PATH" Secure="yes" />
    <Property Id="DOFROOTPATH" Value="C:\DirectOutput" Secure="yes" />
    <!-- BrowseDlg consumes _BrowseProperty as the *name* of the property to populate with the selected folder path. -->
    <Property Id="DOFROOTPATH_BROWSE_PROPERTY" Value="DOFROOTPATH" />
    <Property Id="TOY_TEMPLATE" Value="single_matrix" Secure="yes" />
    <!-- Keep the Finish dialog launch checkbox visible and enabled by default for fresh installs. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Virtual DOF Matrix" />
    <!-- WixUI_InstallDir wires WIXUI_INSTALLDIR internally via InstallDirectory="INSTALLFOLDER"; do not redeclare it here. -->

    <!-- Install root defaults to Program Files and remains user-selectable through the install-directory dialog. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="VirtualDofMatrix" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="$(var.ProductName)" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="DofPayloadFiles" />
    </Feature>

    <!-- Harvest published app artifacts; CI passes InstallerAppPublishDir to package release-ready binaries. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AppPublishDir)**" />
    </ComponentGroup>
    <!-- Ship DOF templates + DirectOutput architecture DLL payload so deferred custom actions can copy from [INSTALLFOLDER]\DOF\. -->
    <ComponentGroup Id="DofPayloadFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DofPayloadDir)**" />
    </ComponentGroup>

    <!-- Provide install-directory selection UI in MSI. -->
    <!-- Bind the MSI license dialog to the repository EULA content instead of the WiX placeholder lorem ipsum. -->
    <WixVariable Id="WixUILicenseRtf" Value="Eula.rtf" />
    <!-- Use an explicit custom UI chain so dialog navigation is fully controlled without colliding with stock WixUI_InstallDir publish rows. -->
    <UI Id="WixUI_InstallDir_Custom">
        <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
        <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
        <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
        <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
        <Property Id="WixUI_Mode" Value="InstallDir" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

        <!-- Reference stock dialogs individually; custom Publish rows below define the authoritative sequence. -->
        <DialogRef Id="BrowseDlg" />
        <DialogRef Id="DiskCostDlg" />
        <DialogRef Id="ErrorDlg" />
        <DialogRef Id="FatalError" />
        <DialogRef Id="FilesInUse" />
        <DialogRef Id="MsiRMFilesInUse" />
        <DialogRef Id="PrepareDlg" />
        <DialogRef Id="ProgressDlg" />
        <DialogRef Id="ResumeDlg" />
        <DialogRef Id="UserExit" />
        <DialogRef Id="WelcomeDlg" />
        <DialogRef Id="LicenseAgreementDlg" />
        <DialogRef Id="InstallDirDlg" />
        <DialogRef Id="VerifyReadyDlg" />
        <DialogRef Id="MaintenanceWelcomeDlg" />
        <DialogRef Id="MaintenanceTypeDlg" />
        <DialogRef Id="ExitDialog" />

        <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />
        <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="LicenseAgreementDlg" Condition="NOT Installed" />
        <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="Installed AND PATCH" />
        <Publish Dialog="LicenseAgreementDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />
        <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="DoAction" Value="DetectDofInstall" Order="1" Condition="LicenseAccepted = &quot;1&quot;" />
        <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="2" Condition="LicenseAccepted = &quot;1&quot; AND DOF_DETECTED = 1" />
        <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="DofNotFoundDlg" Order="3" Condition="LicenseAccepted = &quot;1&quot; AND DOF_DETECTED &lt;&gt; 1" />
        <!-- BrowseDlg requires explicit OK/Cancel control events in custom UI chains to satisfy ICE17/WIX0204 validation. -->
        <Publish Dialog="BrowseDlg" Control="OK" Event="SetTargetPath" Value="[_BrowseProperty]" Order="1" />
        <Publish Dialog="BrowseDlg" Control="OK" Event="EndDialog" Value="Return" Order="2" />
        <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg" />
        <Publish Dialog="InstallDirDlg" Control="Next" Event="CheckTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />
        <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1" />
        <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2" />
        <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="3" />
        <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="TemplateSelectDlg" Order="4" Condition="WIXUI_DONTVALIDATEPATH OR WIXUI_INSTALLDIR_VALID = &quot;1&quot;" />
        <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="TemplateSelectDlg" Order="1" Condition="NOT Installed" />
        <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2" Condition="Installed AND NOT PATCH" />
        <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="Installed AND PATCH" />
        <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />
        <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
        <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
        <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />
        <Property Id="ARPNOMODIFY" Value="1" />
      <UIRef Id="WixUI_Common" />
      <Dialog Id="TemplateSelectDlg" Width="370" Height="270" Title="[ProductName] - Choose LED template">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="Choose LED template" />
        <Control Id="Description" Type="Text" X="20" Y="23" Width="330" Height="24"
          Text="Select the virtual LED layout to install into your DOF config." />

        <!-- Keep this picker intentionally simple so the install flow remains InstallDir -> TemplateSelect -> VerifyReady. -->
        <Control Id="TemplateLabel" Type="Text" X="20" Y="70" Width="330" Height="12" Text="LED template:" />
        <Control Id="TemplateRadioGroup" Type="RadioButtonGroup" X="20" Y="88" Width="330" Height="68" Property="TOY_TEMPLATE">
          <RadioButtonGroup Property="TOY_TEMPLATE">
            <RadioButton Value="single_matrix" X="0" Y="0" Width="320" Height="16" Text="Single matrix" />
            <RadioButton Value="matrix_plus_3_strips" X="0" Y="24" Width="320" Height="16" Text="Matrix and flasher strips" />
          </RadioButtonGroup>
        </Control>

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="DofNotFoundDlg" Width="370" Height="270" Title="[ProductName] - DirectOutput Framework required">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="DirectOutput Framework (DOF) required" />
        <Control Id="Description1" Type="Text" X="20" Y="30" Width="330" Height="28"
          Text="Virtual DOF Matrix requires DirectOutput Framework (DOF) before installation can continue." />
        <Control Id="Description2" Type="Text" X="20" Y="64" Width="330" Height="24"
          Text="DOF is usually installed at C:\DirectOutput, but it may be installed elsewhere." />
        <Control Id="Description3" Type="Text" X="20" Y="94" Width="330" Height="34"
          Text="Install both the 32-bit and 64-bit DOF installers from the mjrnet page, or browse to your existing DOF root folder." />
        <Control Id="SelectedFolderLabel" Type="Text" X="20" Y="136" Width="330" Height="12" Text="Selected DOF root folder:" />
        <Control Id="SelectedFolderPath" Type="Text" X="20" Y="150" Width="330" Height="28" Text="[DOFROOTPATH]" />

        <!-- Keep the browse flow explicit: users pick DOF root, then click Continue to validate Config+x64/x86 layout. -->
        <Control Id="DownloadButton" Type="PushButton" X="20" Y="197" Width="145" Height="17" Text="Open DOF download page">
          <Publish Property="WixShellExecTarget" Value="http://mjrnet.org/pinscape/dll-updates.html#DOF" Order="1" />
          <Publish Event="DoAction" Value="LaunchDofDownloadPage" Order="2" Condition="1" />
        </Control>
        <Control Id="BrowseButton" Type="PushButton" X="174" Y="197" Width="176" Height="17" Text="Browse for DOF folder...">
          <Publish Property="_BrowseProperty" Value="[DOFROOTPATH_BROWSE_PROPERTY]" Order="1" />
          <Publish Event="SpawnDialog" Value="BrowseDlg" Order="2" Condition="1" />
        </Control>

        <Control Id="ContinueButton" Type="PushButton" X="168" Y="243" Width="56" Height="17" Default="yes" Text="Continue">
          <Publish Event="DoAction" Value="DetectDofInstall" Order="1" Condition="1" />
          <Publish Event="NewDialog" Value="InstallDirDlg" Order="2" Condition="DOF_DETECTED = 1" />
          <Publish Event="DoAction" Value="ShowInvalidDofSelectionMessage" Order="3" Condition="DOF_DETECTED &lt;&gt; 1" />
        </Control>
        <Control Id="Exit" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Exit">
          <Publish Event="EndDialog" Value="Exit" Condition="1" />
        </Control>
      </Dialog>

      <!-- Trigger launch from the Exit dialog Finish button only when the optional checkbox remains enabled. -->
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Property="WixShellExecTarget"
        Value="[INSTALLFOLDER]VirtualDofMatrix.App.exe"
        Order="1"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchInstalledApp"
        Order="2"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <!-- DTF custom actions must reference the generated *.CA.dll payload, not the plain project output DLL. -->
    <Binary Id="CustomActionBinary" SourceFile="$(var.CustomActions.TargetDir)VirtualDofMatrix.CustomActions.CA.dll" />
    <CustomAction Id="DetectDofInstall" BinaryRef="CustomActionBinary" DllEntry="DetectDofInstall" Execute="immediate" Return="check" />
    <CustomAction Id="ShowInvalidDofSelectionMessage" BinaryRef="CustomActionBinary" DllEntry="ShowInvalidDofSelectionMessage" Execute="immediate" Return="check" />
    <CustomAction Id="ValidateInstallerSelections" BinaryRef="CustomActionBinary" DllEntry="ValidateInstallerSelections" Execute="immediate" Return="check" />
    <CustomAction Id="ApplyDofTemplateAndBinaries" BinaryRef="CustomActionBinary" DllEntry="ApplyDofTemplateAndBinaries" Execute="deferred" Impersonate="no" Return="check" />
    <CustomAction
      Id="SetApplyDofTemplateAndBinariesData"
      Property="ApplyDofTemplateAndBinaries"
      Value="DOFCONFIGPATH=[DOFCONFIGPATH];DOFROOTPATH=[DOFROOTPATH];BACKUP_ENABLED=[BACKUP_ENABLED];BACKUP_PATH=[BACKUP_PATH];TOY_TEMPLATE=[TOY_TEMPLATE];INSTALLFOLDER=[INSTALLFOLDER]"
      Execute="immediate" />

    <CustomAction
      Id="LaunchInstalledApp"
      BinaryRef="Wix4UtilCA_X64"
      DllEntry="WixShellExec"
      Impersonate="yes" />
    <CustomAction
      Id="LaunchDofDownloadPage"
      BinaryRef="Wix4UtilCA_X64"
      DllEntry="WixShellExec"
      Impersonate="yes" />
    <!-- Populate WixShellExecTarget in the UI sequence after directory resolution so INSTALLFOLDER expansion is legal. -->
    <SetProperty
      Id="WixShellExecTarget"
      Value="[INSTALLFOLDER]VirtualDofMatrix.App.exe"
      After="CostFinalize"
      Sequence="ui" />

    <InstallExecuteSequence>
      <!-- Stage public UI properties into deferred CustomActionData so execute-sequence logic sees the final user selections. -->
      <!-- Run DOF detection in execute sequence as well so passive/silent installs cannot bypass prerequisite checks. -->
      <Custom Action="DetectDofInstall" Before="ValidateInstallerSelections" Condition="NOT Installed AND DOF_DETECTED &lt;&gt; 1" />
      <Custom Action="SetApplyDofTemplateAndBinariesData" Before="ApplyDofTemplateAndBinaries" Condition="NOT Installed" />
      <Custom Action="ValidateInstallerSelections" Before="SetApplyDofTemplateAndBinariesData" Condition="NOT Installed" />
      <Custom Action="ApplyDofTemplateAndBinaries" After="InstallFiles" Condition="NOT Installed AND DOF_DETECTED = 1" />
    </InstallExecuteSequence>
  </Package>
</Wix>
