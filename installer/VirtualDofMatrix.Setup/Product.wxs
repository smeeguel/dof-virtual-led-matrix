<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="$(var.ProductName)"
    Manufacturer="$(var.Manufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="C817B8D6-BF5E-460B-8F7F-6EB79BB66D31"
    Scope="perMachine"
    Language="1033">

    <SummaryInformation Description="Virtual DOF Matrix installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Virtual DOF Matrix is already installed." />
    <!-- Embed cabinets into the MSI so GitHub releases can ship a single installer file without detached cab*.cab payloads. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ARP metadata: name/publisher/version come from Package attributes above; extra fields are explicit here. -->
    <Property Id="ARPCOMMENTS" Value="Virtual DOF Matrix emulator/viewer for DOF serial output." />
    <!-- UI properties are marked Secure so they can flow from client-side UI into deferred execute-sequence custom actions. -->
    <Property Id="DOFCONFIGPATH" Value="C:\DirectOutput\Config" Secure="yes" />
    <Property Id="BACKUP_ENABLED" Value="1" Secure="yes" />
    <Property Id="BACKUP_PATH" Secure="yes" />
    <Property Id="DOFROOTPATH" Value="C:\DirectOutput" Secure="yes" />
    <Property Id="TOY_TEMPLATE" Value="single_matrix" Secure="yes" />
    <!-- Keep the path-validation bypass that avoids false "local hard drive" blocks in InstallDirDlg. -->
    <Property Id="WIXUI_DONTVALIDATEPATH" Value="1" />
    <!-- Keep the Finish dialog launch checkbox visible and enabled by default for fresh installs. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Virtual DOF Matrix" />
    <!-- Keep INSTALLFOLDER rooted in Program Files while still allowing the stock InstallDir picker to change the final path. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="VirtualDofMatrix" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="$(var.ProductName)" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="DofPayloadFiles" />
    </Feature>

    <!-- Harvest published app artifacts; CI passes InstallerAppPublishDir to package release-ready binaries. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.AppPublishDir)**" />
    </ComponentGroup>
    <!-- Ship DOF templates + DirectOutput architecture DLL payload so deferred custom actions can copy from [INSTALLFOLDER]\DOF\. -->
    <ComponentGroup Id="DofPayloadFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DofPayloadDir)**" />
    </ComponentGroup>

    <!-- Provide MSI UI flow and inject DOF configuration pages after the EULA step. -->
    <!-- Bind the MSI license dialog to the repository EULA content instead of the WiX placeholder lorem ipsum. -->
    <WixVariable Id="WixUILicenseRtf" Value="Eula.rtf" />
    <!-- WiX UI extension wiring lives in ui:WixUI, while button event publishing uses the core Publish element under UI. -->
    <UI>
      <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
      <!-- Dialog Title expects plain text or a defined localization string id; do not use undefined WixUI font loc tokens. -->
      <!-- Dedicated "not detected" page keeps the happy path clean: DOF found goes straight to InstallDir, missing stays here with retry help. -->
      <Dialog Id="DofNotFoundDlg" Width="370" Height="270" Title="[ProductName] - DOF not detected">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="DirectOutput Framework not detected" />
        <Control Id="Description" Type="Text" X="20" Y="26" Width="330" Height="40" NoPrefix="yes"
          Text="Virtual DOF Matrix could not detect an existing DirectOutput Framework installation on this machine." />
        <Control Id="Guidance" Type="Text" X="20" Y="70" Width="330" Height="46" NoPrefix="yes"
          Text="Install DirectOutput first, then click Retry to run detection again. The installer will continue automatically when detection succeeds." />
        <Control Id="DownloadLabel" Type="Text" X="20" Y="122" Width="330" Height="12" Text="DOF download:" />
        <Control Id="DownloadUrl" Type="Text" X="20" Y="136" Width="330" Height="24" NoPrefix="yes"
          Text="http://mjrnet.org/pinscape/dll-updates.html#DOF" />
        <Control Id="DetectedPathHint" Type="Text" X="20" Y="166" Width="330" Height="28" NoPrefix="yes"
          Text="Current detected root: [DOFROOTPATH]&#x0d;&#x0a;Current detected config: [DOFCONFIGPATH]" />

        <Control Id="Back" Type="PushButton" X="124" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="LicenseAgreementDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Retry" Type="PushButton" X="184" Y="243" Width="56" Height="17" Default="yes" Text="Retry">
          <!-- Retry always reruns detection, then explicit routing ensures exactly one navigation event fires for this click path. -->
          <Publish Event="DoAction" Value="DetectDofInstall" Condition="NOT Installed" Order="1" />
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="NOT Installed AND DOF_DETECTED = &quot;1&quot;" Order="2" />
          <Publish Event="NewDialog" Value="DofNotFoundDlg" Condition="NOT Installed AND DOF_DETECTED &lt;&gt; &quot;1&quot;" Order="3" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="DofConfigDlg" Width="370" Height="270" Title="[ProductName] - DOF setup options">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="DOF setup options" />
        <Control Id="Description" Type="Text" X="20" Y="23" Width="330" Height="30" Text="Choose your DOF Config folder and backup behavior. Enter the path directly." />

        <Control Id="DofPathLabel" Type="Text" X="20" Y="60" Width="330" Height="12" Text="DOF config folder (DOFCONFIGPATH):" />
        <Control Id="DofPathEdit" Type="PathEdit" X="20" Y="74" Width="330" Height="18" Property="DOFCONFIGPATH" />

        <Control Id="BackupCheck" Type="CheckBox" X="20" Y="112" Width="330" Height="16" Property="BACKUP_ENABLED" CheckBoxValue="1" Text="Enable backup before overwriting files (BACKUP_ENABLED)" />
        <Control Id="BackupPathLabel" Type="Text" X="20" Y="132" Width="330" Height="12" Text="Backup path (BACKUP_PATH):" />
        <Control Id="BackupPathEdit" Type="PathEdit" X="20" Y="146" Width="330" Height="18" Property="BACKUP_PATH" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="TemplateSelectDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="TemplateSelectDlg" Width="370" Height="270" Title="[ProductName] - DOF template selection">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="Choose your starter virtual toys." />
        <!-- Use a RadioButtonGroup so the intended template value is explicit and easy to review. -->
        <Control Id="TemplateGroup" Type="RadioButtonGroup" X="20" Y="76" Width="330" Height="54" Property="TOY_TEMPLATE">
          <RadioButtonGroup Property="TOY_TEMPLATE">
            <RadioButton Value="single_matrix" X="0" Y="0" Width="330" Height="16" Text="Single matrix only" />
            <RadioButton Value="matrix_plus_3_strips" X="0" Y="22" Width="330" Height="16" Text="Matrix and 3 LED strips" />
          </RadioButtonGroup>
        </Control>
        <Control Id="TemplateHint" Type="Text" X="20" Y="138" Width="330" Height="52" NoPrefix="yes"
          Text="You can change the configuration and add/remove virtual toys in the app later." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="DoAction" Value="ValidateInstallerSelections" Condition="1" />
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="DofSummaryDlg" Width="370" Height="270" Title="[ProductName] - Ready to apply DOF setup">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="Confirm DOF setup choices" />
        <Control Id="Description" Type="Text" X="20" Y="23" Width="330" Height="20" Text="Review values before installation starts." />
        <Control Id="SummaryBlock" Type="Text" X="20" Y="50" Width="330" Height="120" NoPrefix="yes"
          Text="DOFCONFIGPATH: [DOFCONFIGPATH]&#x0d;&#x0a;BACKUP_ENABLED: [BACKUP_ENABLED]&#x0d;&#x0a;BACKUP_PATH: [BACKUP_PATH]&#x0d;&#x0a;TOY_TEMPLATE: [TOY_TEMPLATE]" />
        <Control Id="OverwriteWarning" Type="Text" X="20" Y="178" Width="330" Height="28" NoPrefix="yes"
          Text="Warning: existing DOF config files may be overwritten during setup. Keep a backup if needed." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="TemplateSelectDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="NOT Installed" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <!-- Inject detection routing directly after the license page: detected => InstallDir, missing => dedicated not-found page. -->
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="DoAction" Value="DetectDofInstall" Order="98" Condition="LicenseAccepted = &quot;1&quot; AND NOT Installed" />
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="99" Condition="LicenseAccepted = &quot;1&quot; AND NOT Installed AND DOF_DETECTED = &quot;1&quot;" />
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="DofNotFoundDlg" Order="100" Condition="LicenseAccepted = &quot;1&quot; AND NOT Installed AND DOF_DETECTED &lt;&gt; &quot;1&quot;" />
      <!-- Route InstallDir Next to template selection while preserving the stock SetTargetPath behavior from WixUI_InstallDir. -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="TemplateSelectDlg" Order="999" Condition="NOT Installed" />
      <!-- Route VerifyReady Back to template selection for first-time installs only. -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="TemplateSelectDlg" Order="99" Condition="NOT Installed" />
      <!-- Trigger launch from the Exit dialog Finish button only when the optional checkbox remains enabled. -->
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchInstalledApp"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
    </UI>

    <!-- DTF custom actions must reference the generated *.CA.dll payload, not the plain project output DLL. -->
    <Binary Id="CustomActionBinary" SourceFile="$(var.CustomActions.TargetDir)VirtualDofMatrix.CustomActions.CA.dll" />
    <CustomAction Id="DetectDofInstall" BinaryRef="CustomActionBinary" DllEntry="DetectDofInstall" Execute="immediate" Return="check" />
    <CustomAction Id="ShowInvalidDofSelectionMessage" BinaryRef="CustomActionBinary" DllEntry="ShowInvalidDofSelectionMessage" Execute="immediate" Return="ignore" />
    <CustomAction Id="ValidateInstallerSelections" BinaryRef="CustomActionBinary" DllEntry="ValidateInstallerSelections" Execute="immediate" Return="check" />
    <CustomAction Id="ApplyDofTemplateAndBinaries" BinaryRef="CustomActionBinary" DllEntry="ApplyDofTemplateAndBinaries" Execute="deferred" Impersonate="no" Return="check" />
    <CustomAction
      Id="SetApplyDofTemplateAndBinariesData"
      Property="ApplyDofTemplateAndBinaries"
      Value="DOFCONFIGPATH=[DOFCONFIGPATH];DOFROOTPATH=[DOFROOTPATH];BACKUP_ENABLED=[BACKUP_ENABLED];BACKUP_PATH=[BACKUP_PATH];TOY_TEMPLATE=[TOY_TEMPLATE];INSTALLFOLDER=[INSTALLFOLDER]"
      Execute="immediate" />

    <CustomAction
      Id="LaunchInstalledApp"
      BinaryRef="Wix4UtilCA_X64"
      DllEntry="WixShellExec"
      Impersonate="yes" />
    <!-- Populate WixShellExecTarget in the UI sequence after directory resolution so INSTALLFOLDER expansion is legal. -->
    <SetProperty
      Id="WixShellExecTarget"
      Value="[INSTALLFOLDER]VirtualDofMatrix.App.exe"
      After="CostFinalize"
      Sequence="ui" />

    <InstallExecuteSequence>
      <!-- Stage public UI properties into deferred CustomActionData so execute-sequence logic sees the final user selections. -->
      <Custom Action="SetApplyDofTemplateAndBinariesData" Before="ApplyDofTemplateAndBinaries" Condition="NOT Installed" />
      <Custom Action="ValidateInstallerSelections" Before="SetApplyDofTemplateAndBinariesData" Condition="NOT Installed" />
      <Custom Action="ApplyDofTemplateAndBinaries" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Package>
</Wix>
