<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle
    Name="$(var.ProductName)"
    Manufacturer="$(var.Manufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="E01E4CCA-D4FC-4576-BA9C-E3894127B40E">

    <!-- Burn provides setup.exe UX and binds the EULA from the repository root. -->
    <!-- WiX v6 hyperlinkLicense theme requires WixStdbaLicenseUrl to be explicitly defined. -->
    <WixVariable Id="WixStdbaLicenseUrl" Value="https://raw.githubusercontent.com/jsm174/dof-virtual-led-matrix/main/EULA.txt" />
    <BootstrapperApplication>
      <!-- Keep app launch behavior in MSI ExitDialog only; avoids duplicate/competing launch paths in Burn. -->
      <bal:WixStandardBootstrapperApplication
        Theme="hyperlinkLicense"
        LicenseFile="..\..\EULA.txt" />
    </BootstrapperApplication>

    <Chain>
      <MsiPackage SourceFile="$(var.VirtualDofMatrixMsi.TargetPath)" />
    </Chain>
  </Bundle>
</Wix>
