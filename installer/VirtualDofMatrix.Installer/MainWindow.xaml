<Window x:Class="VirtualDofMatrix.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual DOF Matrix Setup"
        Height="430" Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        Closing="Window_Closing">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="72" />
      <RowDefinition Height="*" />
      <RowDefinition Height="52" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Background="#0078D4">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="24,0,0,0">
          <TextBlock Text="Virtual DOF Matrix" Foreground="White"
                     FontSize="18" FontWeight="SemiBold" />
          <TextBlock x:Name="PageSubtitleText" Text="" Foreground="White"
                     FontSize="12" Opacity="0.85" Margin="0,2,0,0" />
        </StackPanel>
        <TextBlock Grid.Column="1" x:Name="StepIndicatorText" Text=""
                   Foreground="White" FontSize="12" VerticalAlignment="Center"
                   Margin="0,0,20,0" Opacity="0.75" />
      </Grid>
    </Border>

    <!-- Page content -->
    <Border Grid.Row="1" Background="White">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ContentPresenter x:Name="PageContent" />
      </ScrollViewer>
    </Border>

    <!-- Footer with navigation buttons -->
    <Border Grid.Row="2" Background="#F3F3F3"
            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="1" x:Name="BackButton"
                Content="← Back"
                Style="{StaticResource SecondaryButton}"
                Width="84" Height="30"
                Margin="0,0,8,0"
                Click="BackButton_Click" />
        <Button Grid.Column="2" x:Name="NextButton"
                Content="Next →"
                Style="{StaticResource PrimaryButton}"
                Width="84" Height="30"
                Margin="0,0,8,0"
                IsDefault="True"
                Click="NextButton_Click" />
        <Button Grid.Column="3" x:Name="CancelButton"
                Content="Cancel"
                Style="{StaticResource SecondaryButton}"
                Width="84" Height="30"
                Margin="0,0,16,0"
                IsCancel="True"
                Click="CancelButton_Click" />
      </Grid>
    </Border>
  </Grid>
</Window>
