<UserControl x:Class="VirtualDofMatrix.Installer.Pages.InstallLocationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="24,14,24,10">

    <TextBlock Style="{StaticResource SectionHeader}" Text="Choose Install Location" />
    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,16"
               Text="Choose the folder where Virtual DOF Matrix will be installed." />

    <!-- Upgrade notice -->
    <Border x:Name="UpgradeBanner" Visibility="Collapsed"
            Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
            CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="↑ " FontSize="16" VerticalAlignment="Center" Foreground="#E65100" />
        <TextBlock x:Name="UpgradeText" Style="{StaticResource BodyText}"
                   VerticalAlignment="Center" Foreground="#E65100" />
      </StackPanel>
    </Border>

    <TextBlock Style="{StaticResource FieldLabel}" Text="Install to:" />
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBox Grid.Column="0" x:Name="InstallFolderBox"
               Style="{StaticResource FormTextBox}"
               TextChanged="InstallFolderBox_TextChanged" />
      <Button Grid.Column="1" Content="Change…"
              Style="{StaticResource SecondaryButton}"
              Margin="6,0,0,0" Height="30" Padding="12,0"
              Click="ChangeButton_Click" />
    </Grid>
    <TextBlock Style="{StaticResource HintText}" Margin="0,6,0,0"
               Text="The application will be installed in the folder above. Administrator access is required to write to Program Files." />

  </StackPanel>
</UserControl>
