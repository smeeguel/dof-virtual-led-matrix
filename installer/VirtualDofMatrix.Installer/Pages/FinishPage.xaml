<UserControl x:Class="VirtualDofMatrix.Installer.Pages.FinishPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="24,14,24,10">

    <!-- Success state -->
    <StackPanel x:Name="SuccessPanel">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
        <Viewbox Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,16,0">
          <Canvas Width="24" Height="24">
            <Polyline Points="3,12 9,18 21,6"
                      Stroke="{StaticResource SuccessBrush}"
                      StrokeThickness="2.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round" />
          </Canvas>
        </Viewbox>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Style="{StaticResource SectionHeader}" FontSize="18"
                     Text="Installation Complete" />
          <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                     Foreground="{StaticResource SecondaryTextBrush}"
                     Text="Virtual DOF Matrix has been installed successfully." />
        </StackPanel>
      </StackPanel>

      <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,16"
                 Text="A shortcut has been added to your Start Menu. Your DOF Config files have been updated with the selected template." />

      <Separator Margin="0,0,0,16" />

      <CheckBox x:Name="LaunchCheckBox"
                Content="Launch Virtual DOF Matrix"
                IsChecked="True"
                FontSize="13"
                Checked="LaunchCheckBox_Changed"
                Unchecked="LaunchCheckBox_Changed" />

      <CheckBox x:Name="OpenConfigToolCheckBox"
                Content="Open DOF Config Tool website (get community matrix shows)"
                IsChecked="False"
                Margin="0,6,0,0"
                Checked="OpenConfigToolCheckBox_Changed"
                Unchecked="OpenConfigToolCheckBox_Changed" />

      <CheckBox x:Name="OpenInstructionsCheckBox"
                Content="Open Instructions in Browser"
                IsChecked="False"
                Margin="0,6,0,0"
                Checked="OpenInstructionsCheckBox_Changed"
                Unchecked="OpenInstructionsCheckBox_Changed" />
    </StackPanel>

  </StackPanel>
</UserControl>
