<UserControl x:Class="VirtualDofMatrix.Installer.Pages.FinishPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="24,28,24,16" VerticalAlignment="Center">

    <!-- Success state -->
    <StackPanel x:Name="SuccessPanel">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
        <TextBlock Text="✓" FontSize="40" Foreground="{StaticResource SuccessBrush}"
                   VerticalAlignment="Center" Margin="0,0,16,0" />
        <StackPanel VerticalAlignment="Center">
          <TextBlock Style="{StaticResource SectionHeader}" FontSize="18"
                     Text="Installation Complete" />
          <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                     Foreground="{StaticResource SecondaryTextBrush}"
                     Text="Virtual DOF Matrix has been installed successfully." />
        </StackPanel>
      </StackPanel>

      <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20"
                 Text="A shortcut has been added to your Start Menu. Your DOF Config files have been updated with the selected template." />

      <CheckBox x:Name="LaunchCheckBox"
                Content="Launch Virtual DOF Matrix"
                IsChecked="True"
                FontSize="13"
                Checked="LaunchCheckBox_Changed"
                Unchecked="LaunchCheckBox_Changed" />
    </StackPanel>

  </StackPanel>
</UserControl>
