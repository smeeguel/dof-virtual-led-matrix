<UserControl x:Class="VirtualDofMatrix.Installer.Pages.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,14,24,10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}"
               x:Name="StatusHeading" Text="Installing…" />

    <ProgressBar Grid.Row="1" x:Name="InstallProgressBar"
                 IsIndeterminate="True"
                 Height="6" Margin="0,10,0,10"
                 Foreground="{StaticResource AccentBrush}"
                 Background="#E0E0E0" BorderThickness="0" />

    <TextBlock Grid.Row="2" x:Name="CurrentStepText"
               Style="{StaticResource HintText}" Margin="0,0,0,8"
               Text="Please wait…" />

    <!-- Scrollable log output -->
    <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            Background="#F9F9F9">
      <ListBox x:Name="LogList"
               BorderThickness="0" Background="Transparent"
               FontFamily="Consolas" FontSize="11"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               SelectionMode="Single" />
    </Border>

    <!-- Error panel (hidden until error) -->
    <Border Grid.Row="4" x:Name="ErrorPanel" Visibility="Collapsed"
            Background="#FFF0F0" BorderBrush="#F0A0A0" BorderThickness="1"
            CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
      <TextBlock x:Name="ErrorText" Style="{StaticResource BodyText}"
                 Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" />
    </Border>
  </Grid>
</UserControl>
