<UserControl x:Class="VirtualDofMatrix.Installer.Pages.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,14,24,10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,10">
      <TextBlock x:Name="TitleText" Style="{StaticResource SectionHeader}"
                 Text="Welcome to Virtual DOF Matrix Setup" />
      <TextBlock Style="{StaticResource BodyText}"
                 Text="Please review the license agreement. You must accept its terms to continue." />
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
      <RichTextBox x:Name="EulaBox"
                   IsReadOnly="True"
                   BorderThickness="0"
                   Padding="8"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   Background="White"
                   VerticalScrollBarVisibility="Auto" />
    </Border>

    <CheckBox Grid.Row="2" x:Name="AcceptCheckBox"
              Margin="0,10,0,0"
              Content="I accept the terms of the License Agreement"
              Checked="AcceptCheckBox_Changed"
              Unchecked="AcceptCheckBox_Changed" />
  </Grid>
</UserControl>
