<UserControl x:Class="VirtualDofMatrix.Installer.Pages.DofConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="24,14,24,10">

    <TextBlock Style="{StaticResource SectionHeader}" Text="DOF Configuration" />
    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,16"
               Text="Confirm where your DOF Config folder is located and choose backup settings." />

    <TextBlock Style="{StaticResource FieldLabel}" Text="DOF Config folder (must end with \Config):" />
    <Grid Margin="0,0,0,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBox Grid.Column="0" x:Name="DofConfigPathBox"
               Style="{StaticResource FormTextBox}"
               TextChanged="DofConfigPathBox_TextChanged" />
      <Button Grid.Column="1" Content="Browse…"
              Style="{StaticResource SecondaryButton}"
              Margin="6,0,0,0" Height="30" Padding="10,0"
              Click="BrowseConfigButton_Click" />
    </Grid>
    <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,16"
               Text="Example: C:\DirectOutput\Config" />

    <Separator Margin="0,0,0,14" />

    <CheckBox x:Name="BackupCheckBox"
              Content="Back up existing DOF Config files before installing"
              IsChecked="True"
              Margin="0,0,0,10"
              Checked="BackupCheckBox_Changed"
              Unchecked="BackupCheckBox_Changed" />

    <TextBlock Style="{StaticResource FieldLabel}" x:Name="BackupPathLabel"
               Text="Backup destination:" />
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBox Grid.Column="0" x:Name="BackupPathBox"
               Style="{StaticResource FormTextBox}"
               TextChanged="BackupPathBox_TextChanged" />
      <Button Grid.Column="1" Content="Browse…"
              Style="{StaticResource SecondaryButton}"
              Margin="6,0,0,0" Height="30" Padding="10,0"
              Click="BrowseBackupButton_Click" />
    </Grid>
    <TextBlock Style="{StaticResource HintText}" Margin="0,6,0,0"
               Text="A timestamped snapshot of your current Config folder will be saved here." />

  </StackPanel>
</UserControl>
