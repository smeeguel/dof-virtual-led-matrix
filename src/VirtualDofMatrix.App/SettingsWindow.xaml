<Window x:Class="VirtualDofMatrix.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual DOF Matrix Settings"
        Width="700"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <DockPanel Margin="12">
        <Border DockPanel.Dock="Top" BorderThickness="1" BorderBrush="#DDD" Background="#F7F7F7" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="SummaryText" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryStatusText" Foreground="#666" />
            </StackPanel>
        </Border>

        <TabControl>
            <TabItem Header="Display">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock FontWeight="SemiBold" Text="Dot Resolution" />
                        <ComboBox x:Name="ResolutionPresetCombo" Margin="0,4,0,0" SelectionChanged="OnResolutionPresetChanged"
                                  ToolTip="Choose a matrix size preset. Custom lets you enter width/height manually."/>

                        <StackPanel x:Name="CustomResolutionPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Width"/>
                                <TextBox x:Name="WidthTextBox" Width="120" TextChanged="OnTextSettingChanged"
                                         ToolTip="Number of horizontal dots (LED columns)."/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Height"/>
                                <TextBox x:Name="HeightTextBox" Width="120" TextChanged="OnTextSettingChanged"
                                         ToolTip="Number of vertical dots (LED rows)."/>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Always on top" Margin="0,12,0,0" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                  ToolTip="Keep matrix window above other windows."/>

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Scale mode"/>
                        <ComboBox x:Name="ScaleModeCombo" Margin="0,4,0,0" SelectionChanged="OnSettingChanged"
                                  ToolTip="Nearest keeps sharp pixel edges. Smooth blends pixels for softer scaling."/>

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Dot shape"/>
                        <ComboBox x:Name="DotShapeCombo" Margin="0,4,0,0" SelectionChanged="OnSettingChanged"
                                  ToolTip="Circle mimics LED lenses. Square looks more pixel-like."/>

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Visual quality"/>
                        <ComboBox x:Name="QualityCombo" Margin="0,4,0,0" SelectionChanged="OnQualityChanged"
                                  ToolTip="Low is fastest. High is prettiest. Custom exposes effect controls."/>

                        <StackPanel x:Name="CustomQualityPanel" Margin="0,8,0,0" Visibility="Collapsed">
                            <CheckBox x:Name="ToneMappingCheckBox" Content="Tonemapping" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="Compresses highlights so bright colors clip less harshly."/>
                            <CheckBox x:Name="TemporalSmoothingCheckBox" Content="Temporal smoothing" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="Smooths frame-to-frame changes to reduce flicker."/>
                            <CheckBox x:Name="BloomCheckBox" Content="Bloom" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="Adds a soft glow around bright pixels."/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="DOF / Cabinet">
                <StackPanel Margin="8">
                    <TextBlock FontWeight="SemiBold" Text="Cabinet.xml"/>
                    <DockPanel Margin="0,4,0,0">
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="100" Margin="8,0,0,0" Click="OnBrowseCabinetXml"/>
                        <TextBox x:Name="CabinetPathTextBox" IsReadOnly="True" ToolTip="Path to Cabinet.xml used for DOF toy width/height updates."/>
                    </DockPanel>

                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="LedStrip toy"/>
                    <ComboBox x:Name="LedStripCombo" Margin="0,4,0,0" IsEditable="True" IsReadOnly="False" SelectionChanged="OnSettingChanged"
                              ToolTip="Target LedStrip name inside Cabinet.xml (example: Matrix1)."/>

                    <CheckBox x:Name="AutoUpdateCabinetCheckBox" Margin="0,12,0,0" Content="Auto-update Cabinet.xml when resolution changes"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                              ToolTip="When enabled, width/height is written to the selected LedStrip on Apply/OK."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Advanced">
                <StackPanel Margin="8">
                    <CheckBox x:Name="DebugCheckBox" Content="Debug logging" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                              ToolTip="Logs detailed protocol and rendering activity for troubleshooting."/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Apply" Width="80" Margin="0,0,8,0" Click="OnApply" />
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="OnOk" />
            <Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </DockPanel>
</Window>
