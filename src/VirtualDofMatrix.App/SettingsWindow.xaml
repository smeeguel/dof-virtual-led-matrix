<Window x:Class="VirtualDofMatrix.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual DOF Matrix Settings"
        Width="700"
        Height="560"
        MinWidth="640"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="RowActionIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderThickness="1" BorderBrush="#DDD" Background="#F7F7F7" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="SummaryText" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryStatusText" Foreground="#666" />
            </StackPanel>
        </Border>

        <TabControl x:Name="SettingsTabs" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TabItem Header="Virtual Toys" ToolTip="Virtual toys are editable; hardware toys are summarized as read-only.">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#666"
                                   Text="Create toys with a guided wizard, or edit an existing one." />
                        <Button x:Name="AddToyButton"
                                DockPanel.Dock="Right"
                                Content="Add Toy"
                                Width="110"
                                Click="OnAddToyClicked"
                                ToolTip="Open the add toy wizard with friendly guided steps." />
                    </DockPanel>

                    <Grid x:Name="VirtualToysHeaderGrid" Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition x:Name="VirtualToysScopeHeaderColumn" Width="0" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Global"
                                   FontWeight="SemiBold"
                                   Foreground="#444"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   ToolTip="Global enabled state. Used when no table override exists." />
                        <TextBlock x:Name="VirtualToysScopeHeaderText"
                                   Grid.Column="1"
                                   FontWeight="SemiBold"
                                   Foreground="#444"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Visibility="Collapsed"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ShowDuration="120000"
                                   ToolTip="Table override enabled state. When present, table value takes precedence over global." />
                    </Grid>

                    <ListBox x:Name="VirtualToysList"
                             Grid.Row="2"
                             IsHitTestVisible="True"
                             Margin="0,0,0,8"
                             AllowDrop="True"
                             Drop="OnVirtualToysListDrop" />

                    <Border Grid.Row="3" Margin="0,12,0,0" Padding="10,8" BorderBrush="#DDD" BorderThickness="1" Background="#FAFAFA">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <Button x:Name="SaveGlobalButton"
                                        DockPanel.Dock="Right"
                                        Content="Save Global"
                                        Width="110"
                                        Visibility="Collapsed"
                                        Click="OnSaveGlobalVirtualToys" />
                                <Button x:Name="SaveScopeButton"
                                        DockPanel.Dock="Right"
                                        Content="Save Scope"
                                        Width="140"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        Click="OnSaveScopedVirtualToys" />
                            </DockPanel>
                            <TextBlock x:Name="HardwareSummaryHeaderText" FontWeight="SemiBold" Text="Hardware Toys (read-only): 0" />
                            <ItemsControl x:Name="HardwareNamesItemsControl" Margin="0,6,0,0" IsHitTestVisible="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="#444" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Display" ToolTip="Global renderer and quality settings.">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                        <StackPanel Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold" Text="Dot Resolution"
                                       ToolTip="Legacy global matrix controls are now managed per toy in Virtual Toys." />
                            <ComboBox x:Name="ResolutionPresetCombo" Margin="0,4,0,0" SelectionChanged="OnResolutionPresetChanged"/>
                            <StackPanel x:Name="CustomResolutionPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Width"/>
                                    <TextBox x:Name="WidthTextBox" Width="120" TextChanged="OnTextSettingChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Height"/>
                                    <TextBox x:Name="HeightTextBox" Width="120" TextChanged="OnTextSettingChanged"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Always on top" Margin="0,12,0,0" Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Dot shape"/>
                            <ComboBox x:Name="DotShapeCombo" Margin="0,4,0,0" SelectionChanged="OnDotShapeChanged"/>
                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Dot brightness"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                                <Slider x:Name="DotBrightnessSlider"
                                        Width="260"
                                        Minimum="0"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        SmallChange="0.05"
                                        LargeChange="0.05"
                                        ValueChanged="OnDotBrightnessChanged" />
                                <TextBlock x:Name="DotBrightnessValueText"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#333"
                                           Text="1.00" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Visual quality"
                                   ToolTip="Low = flat/fast primitive path. High = full primitive effects. Custom = respect JSON values."/>
                        <ComboBox x:Name="QualityCombo" Margin="0,4,0,0" SelectionChanged="OnQualityChanged"
                                  ToolTip="Select a quality profile for performance versus visual fidelity."/>

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Renderer"
                                   ToolTip="GPU uses the hardware-accelerated renderer. CPU uses software rendering."/>
                        <ComboBox x:Name="RendererCombo" Margin="0,4,0,0" SelectionChanged="OnSettingChanged"
                                  ToolTip="Select matrix renderer backend."/>
                        </StackPanel>
                    </ScrollViewer>

                    <DockPanel Grid.Row="1" Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right"
                                Content="Reset to Defaults"
                                Width="130"
                                Click="OnResetDisplayDefaults"
                                ToolTip="Reset only Display-tab settings to app defaults." />
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="DOF / Cabinet" ToolTip="Cabinet.xml detection and LedStrip targeting.">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontWeight="SemiBold" Text="Cabinet.xml" ToolTip="DOF Cabinet configuration file path."/>
                        <TextBlock Margin="8,0,0,0" Foreground="#666" Text="(typically in DirectOutput/Config)" />
                    </StackPanel>
                    <DockPanel Margin="0,4,0,0">
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="100" Margin="8,0,0,0" Click="OnBrowseCabinetXml"
                                ToolTip="Select Cabinet.xml manually."/>
                        <TextBox x:Name="CabinetPathTextBox" IsReadOnly="True" ToolTip="Path used for LedStrip Width/Height updates."/>
                    </DockPanel>

                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="LedStrip toy"
                               ToolTip="Target LedStrip name inside Cabinet.xml (for resolution updates)."/>
                    <ComboBox x:Name="LedStripCombo" Margin="0,4,0,0" IsEditable="True" IsReadOnly="False" SelectionChanged="OnSettingChanged"
                              ToolTip="Select or type the LedStrip toy name (example: Matrix1)."/>

                    <CheckBox x:Name="AutoUpdateCabinetCheckBox" Margin="0,12,0,0" Content="Auto-update Cabinet.xml when resolution changes"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                              ToolTip="When enabled, Width/Height is written on Apply/OK if resolution changed."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Advanced" ToolTip="Debug and advanced troubleshooting options.">
                <StackPanel Margin="8">
                    <CheckBox x:Name="DebugCheckBox" Content="Debug logging" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                              ToolTip="Logs detailed protocol and rendering activity for troubleshooting."/>
                    <CheckBox x:Name="LogFramesCheckBox" Margin="24,6,0,0" Content="Log Frames" Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                              ToolTip="Logs per-frame named-pipe payload lines (for example: Pipe frame seq=..., payload=... bytes)."/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Margin="0,10,0,0" Padding="10,8" BorderBrush="#DDD" BorderThickness="1" Background="#F9F9F9"
                HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="OK" Width="80" Margin="0,0,8,0" Click="OnOk" />
                <Button Grid.Column="2" Content="Cancel" Width="80" IsCancel="True" Click="OnCancel" />
            </Grid>
        </Border>
    </Grid>
</Window>
