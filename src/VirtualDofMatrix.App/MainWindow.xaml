<Window x:Class="VirtualDofMatrix.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual DOF Matrix"
        Background="Black"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False"
        MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Foreground="Lime" FontSize="20" FontWeight="Bold" Text="Virtual DOF Matrix (Milestone 2 bootstrap)" />
            <TextBlock Margin="0,12,0,0" Foreground="White" Text="Rendering pipeline hookup in progress." />
            <TextBlock Foreground="White" Text="Protocol engine remains in VirtualDofMatrix.Core." />
            <TextBlock Margin="0,12,0,0" Foreground="White" Text="Config summary:" />
            <TextBlock Foreground="White" Text="{Binding Serial.PortName, StringFormat=Port: {0}}" />
            <TextBlock Foreground="White" Text="{Binding Matrix.Mapping, StringFormat=Mapping: {0}}" />
            <TextBlock Foreground="White" Text="{Binding Matrix.InstantTrigger, StringFormat=InstantTrigger: {0}}" />
            <TextBlock Foreground="White" Text="{Binding Matrix.Width, StringFormat=Matrix Width: {0}}" />
            <TextBlock Foreground="White" Text="{Binding Matrix.Height, StringFormat=Matrix Height: {0}}" />
        </StackPanel>
    </Grid>
</Window>
