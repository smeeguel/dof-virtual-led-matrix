<Window x:Class="VirtualDofMatrix.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual DOF Matrix"
        Background="Black"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowActivated="False"
        AllowsTransparency="False"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        RenderOptions.BitmapScalingMode="NearestNeighbor"
        RenderOptions.EdgeMode="Aliased">
        <Window.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Settings..." Click="OnSettingsMenuClick" />
                <MenuItem x:Name="ShowDebugMenuItem" Header="Show Debug" IsCheckable="True" Click="OnShowDebugClick" />
                <Separator />
                <MenuItem Header="Exit" Click="OnExitMenuClick" />
            </ContextMenu>
        </Window.ContextMenu>
    <Grid x:Name="RootGrid" Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="DebugSpacerColumn" Width="24" />
            <ColumnDefinition x:Name="DebugPanelColumn" Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border x:Name="MatrixViewportBorder" Grid.Column="0" Background="Black" BorderBrush="#222" BorderThickness="1" Padding="8">
            <Viewbox Stretch="Uniform" StretchDirection="Both">
                <Grid Background="Black">
                    <Canvas x:Name="MatrixCanvas" Background="Black" />
                    <Image x:Name="MatrixImage" Stretch="None" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                </Grid>
            </Viewbox>
        </Border>

        <StackPanel x:Name="DebugPanel" Grid.Column="2">
            <TextBlock Foreground="Lime" FontSize="20" FontWeight="Bold" Text="Virtual DOF Matrix" />
            <TextBlock x:Name="RendererText" Margin="0,12,0,0" Foreground="White" Text="Renderer: (none)" />
            <TextBlock Margin="0,12,0,0" Foreground="White" Text="Config summary:" />
            <TextBlock Foreground="White" Text="{Binding Matrix.Mapping, StringFormat=Mapping: {0}}" />
            <TextBlock Foreground="White" Text="{Binding Matrix.Width, StringFormat=Matrix Width: {0}}" />
            <TextBlock Foreground="White" Text="{Binding Matrix.Height, StringFormat=Matrix Height: {0}}" />

            <TextBlock Margin="0,12,0,0" Foreground="White" Text="Visual options:" />
            <TextBlock x:Name="VisualQualityText" Foreground="White" Text="Visual quality: (none)" />
            <TextBlock x:Name="DotShapeText" Foreground="White" Text="Dot shape: (none)" />
            <TextBlock x:Name="DotSizeText" Foreground="White" Text="Dot size: (none)" />
            <TextBlock x:Name="DotSpacingText" Foreground="White" Text="Min dot spacing: (none)" />
            <TextBlock x:Name="BrightnessText" Foreground="White" Text="Brightness: (none)" />
            <TextBlock x:Name="GammaText" Foreground="White" Text="Gamma: (none)" />
            <TextBlock x:Name="FpsText" Foreground="White" Text="FPS: 0.0" />

            <TextBlock Margin="0,12,0,0" Foreground="White" Text="Last presentation:" />
            <TextBlock x:Name="OutputSequenceText" Foreground="White" Text="Output sequence: (none)" />
            <TextBlock x:Name="PresentedAtText" Foreground="White" Text="Presented at UTC: (none)" />
            <TextBlock x:Name="PayloadLengthText" Foreground="White" Text="Payload bytes: (none)" />
        </StackPanel>
    </Grid>
</Window>
